{
  "name": "Gmail",
  "description": "Read Gmail emails",
  "entrypoint": "index.js",
  "plugin_params": ["credentials_path", "token_path","obj"],

  "functions": [
    {
      "name": "getEmails",
      "description": "Fetch recent Gmail messages based on query",
      "async": true,
      "requires_LLM": true,
      "output_format": [
        {
          "from": "Sender email",
          "subject": "Email subject",
          "date": "Email date"
        }
      ],
      "keywords": [
        "email",
        "gmail",
        "inbox",
        "mail",
        "message",
        "messages",
        "from",
        "subject",
        "today",
        "this week"
      ],
      "requires": ["$INPUT"]
    }
  ],
  "workflows": [
    {
      "name": "send_email",
      "description": "Collect email details and send an email from the user's Gmail account",
      "keywords": [
        "send mail",
        "send a mail",
        "send an email to",
        "send mail to",
        "email to",
        "mail to",
        "send email",
        "send an email",
        "email john",
        "mail john",
        "compose email",
        "write an email",
        "write mail",
        "compose mail",
        "send email",
        "send an email",
        "send mail"
      ],
      "required_params": [
        {
          "name": "recipient",
          "description": "Please provide recipient name or email address.",
          "type": "string"
        },
        {
          "name": "subject",
          "description": "Please provide the email subject.",
          "type": "string"
        },
        {
          "name": "body",
          "description": "Please provide the email body.",
          "type": "string"
        }
      ],
      "optional_params": [
        {
          "name": "cc",
          "description": "Optional: provide a CC email address.",
          "type": "email"
        }
      ],
      "execute": "sendEmailWorkflow"
    }
  ]
}
